#include <NewPing.h>

#define TRIG_PIN 27
#define ECHO_PIN 26
#define MAX_DISTANCE 400

NewPing sonar(TRIG_PIN, ECHO_PIN, MAX_DISTANCE);

void setup() {
  Serial.begin(115200);
  delay(1000);
  Serial.println("\n=== Ultrasonic Test ===");
}

void loop() {
  delay(1000);
  unsigned int distance = sonar.ping_cm();
  if (distance == 0) {
    Serial.println("Out of range or no echo");
  } else {
    Serial.print("Distance: ");
    Serial.print(distance);
    Serial.println(" cm");
  }
}
