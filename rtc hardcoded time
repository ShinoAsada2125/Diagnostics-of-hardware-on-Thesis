#include <Wire.h>
#include <RTClib.h>

RTC_DS3231 rtc;

void setup() {
  Serial.begin(115200);
  delay(1000);
  Serial.println("\n=== Hardcode Time to DS3231 ===");

  Wire.begin();

  if (!rtc.begin()) {
    Serial.println("❌ DS3231 not found. Check wiring.");
    while (1) delay(1000);
  }
  Serial.println("✅ DS3231 detected.");

  // ===== HARDCODE THE TIME HERE =====
  // Change these numbers to your desired date/time
  // Format: year, month, day, hour, minute, second
  rtc.adjust(DateTime(2026, 3, 12, 16, 2, 0));  // Example: March 12, 2026, 3:45:00 PM
  // ===================================

  Serial.println("✅ Time has been set to the hardcoded value.");

  // Read back and print the time to verify
  DateTime now = rtc.now();
  char buf[30];
  snprintf(buf, sizeof(buf), "%04d-%02d-%02d %02d:%02d:%02d",
           now.year(), now.month(), now.day(),
           now.hour(), now.minute(), now.second());
  Serial.print("Current time: ");
  Serial.println(buf);
}

void loop() {
  // Print time every 5 seconds to verify it's counting
  static unsigned long lastPrint = 0;
  if (millis() - lastPrint >= 5000) {
    lastPrint = millis();
    DateTime now = rtc.now();
    char buf[30];
    snprintf(buf, sizeof(buf), "%04d-%02d-%02d %02d:%02d:%02d",
             now.year(), now.month(), now.day(),
             now.hour(), now.minute(), now.second());
    Serial.println(buf);
  }
  delay(10);
}
