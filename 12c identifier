#include <Wire.h>

// Function definition BEFORE setup
void scanI2C(TwoWire &wire) {
  byte error, address;
  int nDevices = 0;
  for (address = 1; address < 127; address++) {
    wire.beginTransmission(address);
    error = wire.endTransmission();
    if (error == 0) {
      Serial.print("  Device found at 0x");
      if (address < 16) Serial.print("0");
      Serial.print(address, HEX);
      // Try to identify common devices
      if (address == 0x20) Serial.print(" (PCF8575)");
      else if (address == 0x27) Serial.print(" (LCD 0x27)");
      else if (address == 0x3F) Serial.print(" (LCD 0x3F)");
      else if (address == 0x38) Serial.print(" (AHT20)");
      else if (address == 0x39) Serial.print(" (AHT20 alternative)");
      Serial.println();
      nDevices++;
    }
  }
  if (nDevices == 0) Serial.println("  No devices found.");
}

void setup() {
  Serial.begin(115200);
  delay(1000);
  Serial.println("\n=== I2C Scanner ===");

  // First bus (Wire) on pins 21/22
  Wire.begin(21, 22);
  Serial.println("Scanning Wire (SDA=21, SCL=22)...");
  scanI2C(Wire);

  // Second bus (Wire1) on pins 32/33
  Wire1.begin(32, 33);
  Serial.println("\nScanning Wire1 (SDA=32, SCL=33)...");
  scanI2C(Wire1);

  Serial.println("\nDone.");
}

void loop() {}
