/*
================================================================================
LoRa Module Diagnostic (RX/TX + Pin Test)
- Tests SPI communication via radio.begin()
- Serial menu: receiver, transmitter, continuous modes, pin checks.
================================================================================
*/

#include <Arduino.h>
#include <RadioLib.h>

// ========== Hardware Pins (adjust to your wiring) ==========
#define LORA_CS    5
#define LORA_DIO0  4
#define LORA_RST   14
#define LORA_SCK   18
#define LORA_MISO  19
#define LORA_MOSI  23

// ========== Radio Configuration ==========
#define LORA_FREQ     433.0
#define LORA_BW       125.0
#define LORA_SF       7
#define LORA_CR       5
#define LORA_SYNC     0x12
#define FREQ_OFFSET   +7000
#define TX_POWER      17

Module mod = Module(LORA_CS, LORA_DIO0, LORA_RST);
SX1278 radio = SX1278(&mod);

void testPins();
void receiverLoop(bool continuous);
void transmitterLoop(bool continuous);
void printMenu();

void setup() {
  Serial.begin(115200);
  delay(1000);
  Serial.println("\n=====================================");
  Serial.println("   LoRa Module Diagnostic Tool");
  Serial.println("=====================================");
  Serial.println("Make sure antenna is connected!");

  pinMode(LORA_DIO0, INPUT_PULLDOWN);
  pinMode(LORA_RST, OUTPUT);
  digitalWrite(LORA_RST, HIGH);

  // Test SPI by attempting to initialize the radio
  Serial.println("\n🔌 Testing SPI communication...");
  SPI.begin(LORA_SCK, LORA_MISO, LORA_MOSI, LORA_CS);

  // Hardware reset
  digitalWrite(LORA_RST, LOW);
  delay(100);
  digitalWrite(LORA_RST, HIGH);
  delay(200);

  int state = radio.begin(LORA_FREQ + (FREQ_OFFSET / 1e6),
                          LORA_BW, LORA_SF, LORA_CR, LORA_SYNC, TX_POWER);
  if (state == RADIOLIB_ERR_NONE) {
    Serial.println("   ✅ Radio initialized – SPI communication OK.");
    radio.sleep(); // go to sleep to save power
  } else {
    Serial.printf("   ❌ Radio begin failed (code %d). Check wiring.\n", state);
  }

  printMenu();
}

void loop() {
  if (Serial.available()) {
    char c = Serial.read();
    switch (c) {
      case '1': receiverLoop(false); printMenu(); break;
      case '2': receiverLoop(true);  printMenu(); break;
      case '3': transmitterLoop(false); printMenu(); break;
      case '4': transmitterLoop(true);  printMenu(); break;
      case '5': testPins(); printMenu(); break;
      case 'm': printMenu(); break;
    }
  }
  delay(10);
}

bool initRadio(bool enableCRC = true) {
  digitalWrite(LORA_RST, LOW); delay(100);
  digitalWrite(LORA_RST, HIGH); delay(200);
  float freq = LORA_FREQ + (FREQ_OFFSET / 1e6);
  int state = radio.begin(freq, LORA_BW, LORA_SF, LORA_CR, LORA_SYNC, TX_POWER);
  if (state != RADIOLIB_ERR_NONE) return false;
  if (enableCRC) radio.setCRC(true);
  return true;
}

void testPins() {
  Serial.println("\n--- Pin Test ---");
  Serial.print("   DIO0 (idle): ");
  Serial.println(digitalRead(LORA_DIO0) ? "HIGH" : "LOW");

  if (!initRadio(true)) {
    Serial.println("   ❌ Radio init failed – CS or SPI problem.");
    return;
  }
  Serial.println("   ✅ Radio initialized – CS and SPI seem OK.");

  radio.startReceive();
  delay(100);
  Serial.print("   DIO0 after startReceive: ");
  Serial.println(digitalRead(LORA_DIO0) ? "HIGH" : "LOW");

  // Reset test
  digitalWrite(LORA_RST, LOW); delay(10);
  digitalWrite(LORA_RST, HIGH); delay(50);
  float freq = LORA_FREQ + (FREQ_OFFSET / 1e6);
  if (radio.begin(freq, LORA_BW, LORA_SF, LORA_CR, LORA_SYNC, TX_POWER) == RADIOLIB_ERR_NONE) {
    Serial.println("   ✅ Reset pin works – chip responded after reset.");
  } else {
    Serial.println("   ❌ Reset pin may not be working.");
  }
  Serial.println("--- Pin Test Complete ---");
}

void receiverLoop(bool continuous) {
  if (!initRadio(true)) return;
  radio.startReceive();
  Serial.println("📡 Waiting for packets... (press any key to stop)");
  unsigned long lastPrint = 0;
  uint8_t buf[256];
  do {
    if (digitalRead(LORA_DIO0) == HIGH) {
      int state = radio.readData(buf, 255);
      if (state == RADIOLIB_ERR_NONE) {
        buf[255] = 0;
        float rssi = radio.getRSSI();
        float snr = radio.getSNR();
        long freqErr = radio.getFrequencyError();
        Serial.printf("\n✅ Packet: \"%s\"\n", (char*)buf);
        Serial.printf("   RSSI: %.1f dBm | SNR: %.1f dB | FreqErr: %ld Hz\n",
                      rssi, snr, freqErr);
        if (!continuous) break;
      } else if (state == RADIOLIB_ERR_CRC_MISMATCH) {
        Serial.println("⚠️  CRC mismatch");
      } else {
        Serial.printf("⚠️  Read error %d\n", state);
      }
      radio.startReceive();
    }
    if (millis() - lastPrint > 10000) {
      Serial.println("⏳ Still listening... (no packet yet)");
      lastPrint = millis();
    }
    if (Serial.available()) { Serial.read(); break; }
    delay(10);
  } while (continuous);
}

void transmitterLoop(bool continuous) {
  if (!initRadio(true)) return;
  int count = 0;
  Serial.println("📤 Sending packets... (press any key to stop)");
  do {
    count++;
    char msg[32];
    snprintf(msg, sizeof(msg), "TEST%d", count);
    Serial.printf("\n📡 TX: \"%s\"\n", msg);
    int state = radio.transmit(msg);
    if (state == RADIOLIB_ERR_NONE) Serial.println("✅ Sent");
    else Serial.printf("❌ TX error %d\n", state);
    if (!continuous) break;
    for (int i = 0; i < 30; i++) { // 3 seconds
      delay(100);
      if (Serial.available()) { Serial.read(); return; }
    }
  } while (continuous);
}

void printMenu() {
  Serial.println("\n--- Menu ---");
  Serial.println("1 - Receive one packet");
  Serial.println("2 - Continuous receive");
  Serial.println("3 - Transmit one packet");
  Serial.println("4 - Continuous transmit");
  Serial.println("5 - Test pins");
  Serial.println("m - Show this menu");
  Serial.print("> ");
}