#include <Wire.h>

#define PCF8575_ADDR 0x20

void pcfWriteAll(uint16_t value) {
  Wire.beginTransmission(PCF8575_ADDR);
  Wire.write(value & 0xFF);
  Wire.write((value >> 8) & 0xFF);
  Wire.endTransmission();
}

void setup() {
  Serial.begin(115200);
  delay(1000);
  Serial.println("\n=== PCF8575 Test ===");

  Wire.begin(21, 22); // First bus

  // Quick scan to verify address
  Wire.beginTransmission(PCF8575_ADDR);
  if (Wire.endTransmission() != 0) {
    Serial.println("❌ PCF8575 not found at 0x20. Check wiring.");
    while (1) delay(1000);
  }
  Serial.println("✅ PCF8575 detected.");

  // Test: Set all pins LOW (relays ON if active‑low)
  Serial.println("Setting all pins LOW for 2 seconds...");
  pcfWriteAll(0x0000);
  delay(2000);

  // Then all HIGH
  Serial.println("Setting all pins HIGH.");
  pcfWriteAll(0xFFFF);

  // Blink each pin
  for (int pin = 0; pin < 16; pin++) {
    Serial.print("Toggling pin "); Serial.println(pin);
    uint16_t val = ~(1 << pin); // all HIGH except this pin LOW
    pcfWriteAll(val);
    delay(500);
  }
  pcfWriteAll(0xFFFF); // all off
  Serial.println("Test complete.");
}

void loop() {}
