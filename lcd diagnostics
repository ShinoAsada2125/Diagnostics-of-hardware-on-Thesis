#include <Wire.h>
#include <LiquidCrystal_I2C.h>

// Set the LCD address (try 0x27 or 0x3F)
#define LCD_ADDR 0x27
#define LCD_COLS 20
#define LCD_ROWS 4

LiquidCrystal_I2C lcd(LCD_ADDR, LCD_COLS, LCD_ROWS);

void setup() {
  Serial.begin(115200);
  delay(1000);
  Serial.println("\n=== LCD Test ===");

  Wire.begin(21, 22); // First bus

  lcd.init();
  lcd.backlight();
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("LCD Test OK!");
  lcd.setCursor(0, 1);
  lcd.print("Address: 0x");
  lcd.print(LCD_ADDR, HEX);

  Serial.println("If you see the message on LCD, it works.");
  Serial.println("If not, try changing LCD_ADDR to 0x3F.");
}

void loop() {}
