/*
================================================================================
HC-SR04 Ultrasonic Sensor Calibration Tool with Volume Calculation
- Reads distance using NewPing library
- Calculates water level and volume based on tank dimensions
- Prints raw distance, water level, and volume to Serial Monitor every second
- Use to compare with actual known water volume (e.g., 5 liters) to calibrate
================================================================================
*/

#include <Arduino.h>
#include <NewPing.h>

// Pin definitions (matching your project)
#define TRIG_PIN      27
#define ECHO_PIN      26
#define MAX_DISTANCE  400   // Maximum range in cm

// Tank dimensions (customize for your tank!)
const float TANK_WIDTH_CM = 19;    // Interior width in cm
const float TANK_LENGTH_CM = 27;   // Interior length in cm
const float TANK_HEIGHT_CM = 16.0;   // Total height in cm

// Create NewPing object
NewPing sonar(TRIG_PIN, ECHO_PIN, MAX_DISTANCE);

void setup() {
  Serial.begin(115200);
  delay(1000);
  Serial.println("\n=== HC-SR04 Calibration Tool with Volume ===");
  Serial.println("Place known amount of water in tank and compare readings.\n");
  Serial.print("Tank dimensions: ");
  Serial.print(TANK_WIDTH_CM); Serial.print(" cm x ");
  Serial.print(TANK_LENGTH_CM); Serial.print(" cm x ");
  Serial.print(TANK_HEIGHT_CM); Serial.println(" cm");
  Serial.println("Expected full volume: " + String((TANK_WIDTH_CM * TANK_LENGTH_CM * TANK_HEIGHT_CM) / 1000.0, 1) + " L");
  Serial.println();
}

void loop() {
  // Take multiple readings and average (similar to main code)
  const int numReadings = 3;
  unsigned int total = 0;
  int valid = 0;

  for (int i = 0; i < numReadings; i++) {
    unsigned int d = sonar.ping_cm();
    if (d > 0 && d <= MAX_DISTANCE) {
      total += d;
      valid++;
    }
    delay(50); // short delay between pings
  }

  if (valid > 0) {
    float raw_distance = (float)total / valid;   // average distance in cm

    // Calculate water level (height of water in tank)
    float water_level = TANK_HEIGHT_CM - raw_distance;
    if (water_level < 0) water_level = 0;
    if (water_level > TANK_HEIGHT_CM) water_level = TANK_HEIGHT_CM;

    // Calculate volume in liters
    float volume = (TANK_WIDTH_CM * TANK_LENGTH_CM * water_level) / 1000.0;

    // Print results
    Serial.print("Raw distance: ");
    Serial.print(raw_distance, 1);
    Serial.print(" cm  |  Water level: ");
    Serial.print(water_level, 1);
    Serial.print(" cm  |  Volume: ");
    Serial.print(volume, 1);
    Serial.println(" L");
  } else {
    Serial.println("No valid reading (out of range or no echo)");
  }

  delay(1000); // wait 1 second before next measurement
}
